# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# iOS generated by Flutter build system
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/

# Android generated plugin registrant
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Gradle cache — contains lock files held by the Gradle daemon (permission errors)
.gradle/
**/.gradle/

# Local configuration
android/local.properties
# Google Services — настоящий файл создаётся CI из секрета GOOGLE_SERVICES_JSON
# Для локальной разработки скопируй google-services.json.example → google-services.json
android/app/google-services.json
