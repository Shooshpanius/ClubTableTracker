<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Базовая конфигурация: только HTTPS, доверяем системным CA -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    <!-- Явная конфигурация для go40k.ru — доверяем системным CA.
         Если сертификат сервера выпущен CA не из стандартного Android trust
         store, необходимо добавить CA-сертификат в Resources/raw/ и
         указать его здесь: <certificates src="@raw/ca_cert"/> -->
    <domain-config>
        <domain>go40k.ru</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
