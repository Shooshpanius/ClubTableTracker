<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 Профиль"
            android:textColor="#e94560"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Имя из Google -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Имя (Google-аккаунт):"
            android:textColor="#aaaaaa"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvGoogleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eeeeee"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="2dp" />

        <!-- Отображаемое имя -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отображаемое имя:"
            android:textColor="#aaaaaa"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/editDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eeeeee"
            android:textColorHint="#666666"
            android:background="#16213e"
            android:padding="10dp"
            android:hint="Оставьте пустым для имени Google"
            android:maxLength="60"
            android:inputType="text"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnSaveName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сохранить имя"
            android:background="#e94560"
            android:textColor="#ffffff"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvNameStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Биография -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="О себе:"
            android:textColor="#aaaaaa"
            android:textSize="12sp"
            android:layout_marginTop="20dp" />

        <EditText
            android:id="@+id/editBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eeeeee"
            android:textColorHint="#666666"
            android:background="#16213e"
            android:padding="10dp"
            android:hint="Расскажите о себе..."
            android:maxLength="500"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="6"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnSaveBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сохранить биографию"
            android:background="#e94560"
            android:textColor="#ffffff"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvBioStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Игровые системы -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Игровые системы:"
            android:textColor="#aaaaaa"
            android:textSize="12sp"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvGameSystemsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eeeeee"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnEditGameSystems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Изменить игровые системы"
            android:background="#0f3460"
            android:textColor="#eeeeee" />

        <!-- Выйти -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выйти из аккаунта"
            android:background="#333355"
            android:textColor="#e94560"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
