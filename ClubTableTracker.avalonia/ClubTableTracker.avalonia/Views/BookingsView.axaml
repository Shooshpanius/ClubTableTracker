<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClubTableTracker.avalonia.ViewModels"
             xmlns:models="using:ClubTableTracker.avalonia.Models"
             x:Class="ClubTableTracker.avalonia.Views.BookingsView"
             x:DataType="vm:BookingsViewModel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Margin="16,16,16,4">
      <TextBlock Text="Мои бронирования"
                 FontSize="24"
                 FontWeight="Bold" />
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="🔄 Обновить"
                Command="{Binding LoadCommand}"
                IsEnabled="{Binding !IsLoading}" />
      </StackPanel>
      <ProgressBar IsVisible="{Binding IsLoading}"
                   IsIndeterminate="True"
                   Height="3"
                   Margin="0,6,0,0" />
    </StackPanel>

    <ScrollViewer Grid.Row="1">
      <StackPanel>

        <TextBlock Text="{Binding EmptyMessage}"
                   HorizontalAlignment="Center"
                   Margin="16,40"
                   Opacity="0.55"
                   FontSize="15"
                   IsVisible="{Binding EmptyMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <ItemsControl ItemsSource="{Binding Bookings}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:BookingDto">
              <Border Margin="8,4" Padding="14,12" CornerRadius="10"
                      Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="6">

                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🎲" FontSize="20" VerticalAlignment="Center" />
                    <StackPanel>
                      <TextBlock FontWeight="SemiBold" FontSize="16">
                        <Run Text="Стол №" />
                        <Run Text="{Binding TableNumber}" />
                      </TextBlock>
                      <TextBlock Text="{Binding ClubName}" Opacity="0.65" FontSize="13" />
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🗓" FontSize="14" />
                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="14" />
                    <TextBlock Text="  " FontSize="14" />
                    <TextBlock Text="⏰" FontSize="14" />
                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}" FontSize="14" />
                    <TextBlock Text="–" FontSize="14" />
                    <TextBlock Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}" FontSize="14" />
                  </StackPanel>

                  <TextBlock FontSize="13" Opacity="0.7"
                             IsVisible="{Binding GameSystem, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Run Text="🎮 " />
                    <Run Text="{Binding GameSystem}" />
                  </TextBlock>

                  <TextBlock FontSize="13" Opacity="0.7">
                    <Run Text="👤 " />
                    <Run Text="{Binding User.Name}" />
                  </TextBlock>

                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Height="16" />

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
