# Google OAuth Client ID from https://console.cloud.google.com/
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID:
#   - Add https://go40k.ru under "Authorised JavaScript origins"
#   - Make sure the same Client ID is used here AND in appsettings.json (Google:ClientId)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Yandex OAuth (Yandex ID). Register at https://oauth.yandex.ru/client/new
# The same ClientID is used by both the client (VITE_YANDEX_CLIENT_ID) and the
# server (Yandex:ClientId). ClientSecret stays on the server only.
YANDEX_CLIENT_ID=your-yandex-client-id
YANDEX_CLIENT_SECRET=your-yandex-client-secret

# VK ID OAuth. Register at https://id.vk.com/business/
# The same ClientID is used by both the client (VITE_VK_CLIENT_ID) and the
# server (Vk:ClientId). ClientSecret stays on the server only.
VK_CLIENT_ID=your-vk-client-id
VK_CLIENT_SECRET=your-vk-client-secret

# JWT secret for signing user tokens (minimum 32 characters, change before deploy!)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long!!

# Master key for system administration panel (/admin). Change before deploy!
MASTER_KEY=your-master-key-change-before-deploy

# MySQL database credentials
DB_USER=clubuser
DB_PASSWORD=your-strong-db-password
DB_ROOT_PASSWORD=your-strong-root-password

# Yandex.Metrika counter ID (number from metrika.yandex.ru).
# Leave empty or set to 0 to disable the counter.
YANDEX_METRIKA_ID=

# Firebase Cloud Messaging: service account JSON for push notifications.
# Required for push notifications in the mobile Flutter app.
# Get it from Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Paste the entire JSON content as a single line (remove line breaks).
# If not set, push notifications are silently disabled (app continues to work normally).
Firebase__ServiceAccountJson=
