# Google OAuth Client ID from https://console.cloud.google.com/
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID:
#   - Add https://club.wh40kcards.ru under "Authorised JavaScript origins"
#   - Make sure the same Client ID is used here AND in appsettings.json (Google:ClientId)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT secret for signing user tokens (minimum 32 characters, change before deploy!)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long!!

# Master key for system administration panel (/admin). Change before deploy!
MASTER_KEY=your-master-key-change-before-deploy

# MySQL database credentials
DB_USER=clubuser
DB_PASSWORD=your-strong-db-password
DB_ROOT_PASSWORD=your-strong-root-password

# Yandex.Metrika counter ID (number from metrika.yandex.ru).
# Leave empty or set to 0 to disable the counter.
YANDEX_METRIKA_ID=
